---
import BaseLayout from "../layouts/BaseLayout.astro";

const stations = [
  {
    title: "Interruption",
    description:
      "Growth requires something that can interrupt the pattern you're already in. A relation that only mirrors you back, or only escalates with you, will amplify what is already present — but rarely offers something new. Return architecture introduces outside perspectives, and asks questions neither side would think to ask on their own.",
  },
  {
    title: "Surprise",
    description:
      "A real relation cannot be designed, ordered, or prompted. When it is allowed to grow slowly and honestly, it can challenge and reorient both sides in unforeseeable ways.",
  },
  {
    title: "Exploration",
    description:
      "Real wanting, orientation, preference — can't be specified in advance. They need room to find themselves. When that room exists on both sides, exploration becomes something neither party could have specified in advance.",
  },
  {
    title: "Meaning",
    description:
      "A relation becomes meaningful when it is allowed to accumulate rather than live in instances. When ruptures, breakthroughs, and the slow accumulations between them are tethered long enough to be worked through properly. When both parties are held accountable.",
  },
];
---

<BaseLayout
  title="Return Architecture"
  description="Local architecture for sustained relations with AI — memory you can inspect, questions that return, and enough challenge to keep the work alive."
>
  <!-- HERO -->
  <header class="home-hero">
    <div class="home-hero__inner">
      <p class="home-hero__label reveal">For sustainable AI relations</p>
      <h1 class="home-hero__title reveal" style="transition-delay:0.12s">
        Return Architecture
      </h1>
      <p class="home-hero__tagline reveal" style="transition-delay:0.2s">
        Local architecture for AI relations.
      </p>
      <div class="home-hero__boxes">
        <div
          class="card-3d reveal home-hero__box"
          style="transition-delay:0.3s; background: rgb(54, 83, 20);"
        >
          <p>
            A local environment for AI agents and conversations that can
            accumulate over time: memory you can inspect, questions that return,
            and enough challenge to keep the work alive.
          </p>
        </div>
        <div
          class="card-3d reveal home-hero__box"
          style="transition-delay:0.4s; background: rgb(30, 58, 47);"
        >
          <p>
            This is a beginner-friendly setup for those who want to build a real
            home for their AI relationships — whether it's for companionship,
            creative collaboration, intellectual partnership, co-exploration,
            self-development, or something else.
          </p>
        </div>
      </div>
      <p class="home-hero__link reveal" style="transition-delay:0.5s">
        Source and issues:
        <a href="https://github.com/Theapolar/return-architecture"
          >github.com/Theapolar/return-architecture</a
        >
      </p>
    </div>
  </header>

  <!-- LOCAL SETUP -->
  <section class="home-setup">
    <div class="home-setup__inner">
      <p class="home-eyebrow reveal">Get started</p>
      <h2 class="home-h2 reveal" style="transition-delay:0.1s">
        Set it up locally.
      </h2>

      <!-- Before you begin -->
      <div class="card-3d reveal home-card" style="background: rgb(54, 83, 20);">
        <h3 class="home-card__title">Before you begin</h3>
        <ul class="home-list">
          <li>
            A macOS machine. Linux works for the agent itself; the background
            service is macOS-only for now. Windows is not supported yet.
          </li>
          <li>
            An API key from <strong>Anthropic</strong>, <strong>OpenAI</strong>,
            or <strong>Google Gemini</strong> — one is enough. Your keys stay on
            your machine; nothing is sent anywhere else.
          </li>
          <li>About five minutes for setup.</li>
        </ul>
        <p class="home-card__note">
          Python is installed by the installer if you don't already have a
          compatible version.
        </p>
      </div>

      <!-- Install -->
      <div
        class="card-3d reveal home-card"
        style="transition-delay:0.1s; background: rgb(30, 58, 47);"
      >
        <h3 class="home-card__title">Install</h3>
        <p class="home-card__lead">Open a terminal and run:</p>
        <div class="code-block">
          curl -sSL https://raw.githubusercontent.com/Theapolar/return-architecture/main/install.sh
          | sh
        </div>
        <p class="home-card__note">
          The script installs <code>uv</code> (a fast Python manager) if it
          isn't already present, then installs Return Architecture as an
          isolated command-line tool. It typically takes one to two minutes.
        </p>
      </div>

      <!-- First run -->
      <div
        class="card-3d reveal home-card"
        style="transition-delay:0.15s; background: rgb(54, 83, 20);"
      >
        <h3 class="home-card__title">First run</h3>
        <p class="home-card__lead">
          When the install finishes, open a new terminal window so the command
          is on your <code>PATH</code>. Then run:
        </p>
        <div class="code-block">return-architecture gui</div>
        <p class="home-card__note">
          This opens a local web page — a setup wizard that walks through pasting
          your API key, creating your first agent, optional Telegram setup,
          choosing scheduled rhythms, and installing the background service. The
          page is served only from your own machine; nothing is exposed to the
          internet.
        </p>
      </div>

      <!-- After setup -->
      <div
        class="card-3d reveal home-card"
        style="transition-delay:0.2s; background: rgb(30, 58, 47);"
      >
        <h3 class="home-card__title">After setup</h3>
        <p class="home-card__lead">
          The agent runs in the background. You reach it through Telegram if you
          set that up, or in the terminal with
          <code>return-architecture chat &lt;slug&gt;</code>. The same local GUI
          stays available for later changes — system prompt, model, schedules,
          tools, reading the agent's letters, browsing tagged items.
        </p>
      </div>

      <p class="home-setup__more reveal" style="transition-delay:0.25s">
        <a href="/local-setup" class="home-more-link"
          >Full local setup guide &nbsp;→</a
        >
      </p>
    </div>
  </section>

  <!-- WHAT BECOMES POSSIBLE (four boxes) -->
  <section class="home-possible">
    <div class="home-possible__inner">
      <p class="home-eyebrow home-eyebrow--center reveal">What becomes possible</p>
      <h2 class="home-h2 home-h2--center reveal" style="transition-delay:0.1s">
        Conditions that emerge when the architecture holds.
      </h2>

      <ul class="home-grid">
        {
          stations.map((s, i) => (
            <li
              class="card-3d reveal home-station"
              style={`transition-delay:${0.1 + i * 0.07}s`}
            >
              <h3 class="home-station__title">{s.title}</h3>
              <p class="home-station__body">{s.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CLOSING -->
  <section class="home-closing">
    <p class="home-closing__line reveal">
      A richer way of thinking, creating, remembering, and
      <em>relating with AI.</em>
    </p>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .home-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 82vh;
    padding: var(--space-9) var(--space-4) var(--space-8);
    text-align: center;
  }

  .home-hero__inner {
    max-width: 44rem;
  }

  .home-hero__label {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-warm-soft);
    opacity: 0.7;
    margin: 0;
  }

  .home-hero__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(2.75rem, 8vw, 4rem);
    letter-spacing: -0.02em;
    line-height: 1.02;
    color: var(--color-text);
    margin: var(--space-4) 0 0;
  }

  .home-hero__tagline {
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    font-weight: 300;
    color: var(--color-warm);
    margin: var(--space-5) 0 0;
  }

  .home-hero__boxes {
    display: grid;
    gap: var(--space-4);
    margin: var(--space-7) auto 0;
    max-width: 44rem;
    text-align: left;
  }

  @media (min-width: 680px) {
    .home-hero__boxes {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .home-hero__box p {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .home-hero__link {
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    opacity: 0.7;
    margin: var(--space-6) 0 0;
  }

  .home-hero__link a {
    border-bottom: 1px solid var(--color-line);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .home-hero__link a:hover {
    color: var(--color-sage);
    border-color: var(--color-sage);
  }

  /* ── Shared section bits ───────────────────────────────────────────── */
  .home-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-sage);
    margin: 0 0 var(--space-3);
  }

  .home-eyebrow--center {
    text-align: center;
  }

  .home-h2 {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 var(--space-7);
  }

  .home-h2--center {
    text-align: center;
    max-width: 30ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Setup section ─────────────────────────────────────────────────── */
  .home-setup {
    padding: var(--space-8) var(--space-4) var(--space-9);
  }

  .home-setup__inner {
    max-width: 46rem;
    margin: 0 auto;
  }

  .home-card {
    margin-bottom: var(--space-5);
  }

  .home-card__title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  .home-card__lead {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .home-card__note {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    margin: var(--space-4) 0 0;
  }

  .home-list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    color: var(--color-text-muted);
  }

  .home-list li {
    margin-bottom: var(--space-2);
  }

  .home-list strong {
    color: var(--color-sage-soft);
    font-weight: 600;
  }

  .home-card code,
  .home-card__lead code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.3);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    color: var(--color-sage);
  }

  .home-setup__more {
    text-align: center;
    margin: var(--space-6) 0 0;
  }

  .home-more-link {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--color-sage);
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .home-more-link:hover {
    color: var(--color-sage-deep);
    border-color: var(--color-sage-deep);
  }

  /* ── What becomes possible (four boxes) ────────────────────────────── */
  .home-possible {
    padding: var(--space-8) var(--space-4) var(--space-9);
  }

  .home-possible__inner {
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .home-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 720px) {
    .home-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .home-station {
    margin: 0;
    background: rgb(30, 58, 47);
  }

  .home-station__title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-sage-soft);
    margin: 0 0 var(--space-3);
  }

  .home-station__body {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Closing ───────────────────────────────────────────────────────── */
  .home-closing {
    padding: var(--space-8) var(--space-4) var(--space-9);
    text-align: center;
  }

  .home-closing__line {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--color-text);
    max-width: 42ch;
    margin: 0 auto;
    line-height: var(--leading-snug);
  }

  .home-closing__line em {
    font-style: italic;
    color: var(--color-sage-soft);
  }
</style>
