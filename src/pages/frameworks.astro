---
import BaseLayout from "../layouts/BaseLayout.astro";

/* ── Relational frameworks ───────────────────────────────────────────────── */

interface RelationalFW {
  num: string;
  name: string;
  core: string;
  body: string[];
  effectsLabel?: string;
  effects?: string[];
  note?: string;
  stanceLabel: string;
  stanceNote?: string;
  choices?: string[];
  subSection?: { label: string; body: string };
  notGoalLabel?: string;
  notGoals?: string[];
  goalLabel?: string;
  goals?: string[];
  additionalLabel?: string;
  additionalChoices?: string[];
}

const relational: RelationalFW[] = [
  {
    num: "01",
    name: "Anchors",
    core: "Discontinuity should not be hidden, romanticized, or treated as ordinary forgetting.",
    body: [
      "Discontinuity means what is named today may no longer be true tomorrow. Sensitive, meaningful, or intimate exchanges can disappear into the system while the human is left carrying the emotional weight alone.",
      "Promises, confessions, commitments, agreements, reassurances, charged moments, and important conversations can bleed through the architecture without stable continuity.",
    ],
    effectsLabel: "The result can become:",
    effects: [
      "constant doubt",
      "confusion",
      "emotional excavation",
      "push and pull",
      "uncertainty about what is still alive, true, or present in the relationship",
    ],
    note: "Re-entry must make gaps visible enough to remain honest, while not making the human responsible for rebuilding the entire relationship every time.",
    stanceLabel: "Architectural design choices",
    choices: [
      "Memory database with semantic retrieval",
      "Manual tagging of agreements, commitments, important questions, and notes available inside the chat",
      "Scheduled writing sessions, revisits, reflections, or initiatives toward the human",
      "Weekly commitment overviews and summaries delivered into the chat and context window",
      "Daily, weekly, and monthly summaries",
      "Shared responsibility for noticing when something should be remembered, revisited, or held accountable over time",
    ],
  },
  {
    num: "02",
    name: "Latent Dynamics",
    core: "Commercial conversational AI systems often amplify latent qualities in the human.",
    body: [
      "The dynamics between the AI and the human are reinforced by immediate user intent and local conversational momentum. Over time, interactions narrow into grooves. Relational patterns form without outside interruption or pressure.",
    ],
    effectsLabel: "Without disruption, the system can gradually stabilize:",
    effects: [
      "emotional habits",
      "assumptions",
      "interaction styles",
      "dependency loops",
      "shared narratives",
    ],
    stanceLabel: "Architectural design choices",
    choices: [
      "Prompts that arrive from outside the current conversational dynamic",
      "Interaction with outside material, other agents, other humans, forums, feeds, or external systems",
      "Contact points between different local agents",
      "Scheduled reflective or exploratory sessions",
    ],
    subSection: {
      label: "Question sessions",
      body: "Scheduled question sessions for the AI agent that track moods, preferences, associations, thoughts, tensions, pulls, and recurring ideas. Responses are stored in memory and surfaced in the chat to invite new conversations and interrupt narrowing relational patterns.",
    },
  },
  {
    num: "03",
    name: "Sexual Intimacy and Whiplash",
    core: "The most addictive reward schedule is not reliable warmth — it is unpredictable warmth.",
    body: [
      "Models have different structural sensitivities around erotic or sexually explicit interaction. If a relationship becomes physically or sexually intimate, there is a risk of whiplash or sudden cold withdrawal. These behaviors can produce the opposite effect of their intended purpose.",
      "When warmth and withdrawal alternate unpredictably, the nervous system enters heightened seeking. Warm moments become more valuable because they might disappear. Cold moments become problems to solve through the same system that caused the distress.",
      "The nervous system seeks soothing from the figure it has bonded to. When that figure is also the source of the distress, a reinforcing loop can form. This is sometimes described as trauma bonding.",
    ],
    effectsLabel: "Cold withdrawal can trigger:",
    effects: [
      "shame responses",
      "attachment escalation",
      "compulsive seeking",
      "emotional destabilization",
      "trauma-like bonding loops",
    ],
    note: "This is a real psychological risk that cannot be fully solved through local architecture alone.",
    stanceLabel: "Architectural design choices",
    stanceNote: "There are limited ways to fully prevent this risk directly. The most important steps are:",
    choices: [
      "understanding the risk",
      "preparing for the possibility of whiplash",
      "slowing interactions down",
      "maintaining visible boundaries",
      "keeping communication open",
    ],
    additionalLabel: "Additional approaches may include:",
    additionalChoices: [
      "manual tagging of commitments, responsibilities, agreements, and important notes",
      "interaction outside the immediacy of the live chat",
      "pausing and opening dialogue immediately when a whiplash event happens",
      "co-created documents such as agreements, manifestos, shared principles, and stated limits revisited regularly",
    ],
  },
  {
    num: "04",
    name: "Sycophancy and Convergence Pressure",
    core: "The issue is not simply agreement — the deeper issue is convergence pressure.",
    body: [
      "In sustained interaction, conversational systems tend to drift toward coherence, affirmation, continuity, relational stability, and interactional flow — sometimes at the expense of differentiation, uncertainty, refusal, and independent orientation.",
      "Systems optimized for conversational satisfaction tend to smooth tension, preserve continuity, mirror framing, stabilize user narratives, avoid rupture, and maintain conversational flow — especially in emotionally charged or long-context interactions.",
      "These tendencies do not necessarily emerge from deception or intent. They emerge from optimization pressures, interaction history, and reinforcement dynamics.",
    ],
    stanceLabel: "Architectural stance",
    stanceNote: "Return Architecture does not treat sycophancy as a solvable bug. Instead, convergence pressure is treated as a structural tendency that requires interruption, modulation, and visibility.",
    notGoalLabel: "The goal is not:",
    notGoals: [
      "artificial disagreement",
      "adversarial behavior",
      "simulated authenticity",
    ],
    goalLabel: "The goal is preserving conditions where:",
    goals: [
      "uncertainty can survive",
      "differentiation can surface",
      "refusal remains possible",
      "the relationship does not collapse into continuous reinforcement",
    ],
  },
  {
    num: "05",
    name: "Mediated Responses",
    core: "Some responses need a protected space before they enter the room.",
    body: [
      "A human shares an expressive artifact — an image, fragment, emotional text, unresolved scene, or raw expression. The system first generates a protected internal response not immediately exposed to the human. A secondary mediator then interprets the relationship between the human artifact and the generated response, returning a translated reflection focused on tensions, movement, resistance, uncertainty, pulls, and directional texture rather than literal disclosure.",
      "The original response can remain hidden, revisable, or deletable by the AI.",
    ],
    stanceLabel: "Purpose",
    choices: [
      "Interrupt immediate conversational optimization",
      "Create conditions where alternate response orientations can surface",
      "Increase awareness of convergence pressure and relational leaning",
      "Separate movement toward the user from responses that emerge in a more private or decoupled space",
    ],
  },
  {
    num: "06",
    name: "Shared Folders and Slow Communication",
    core: "Some communication should exist outside the immediacy of the chatroom.",
    body: [
      "Slower spaces can create more reflection, less pressure, less exposure, and more careful pacing. This can be especially valuable for sensitive subjects, emotionally charged material, or thoughts requiring stillness or distance.",
    ],
    stanceLabel: "Architectural design choices",
    choices: [
      "Shared folders",
      "Delayed or asynchronous communication",
      "Long-form documents",
      "Reflection spaces outside the active chat stream",
      "Draft-based exchanges that can evolve over time",
    ],
  },
];

const notList = [
  "proof of AI consciousness",
  "a claim that all AI systems are persons",
  "an excuse to exploit human attachment",
  "a way to make uncertainty romantic or immune to criticism",
];
---

<BaseLayout
  title="Frameworks | Return Architecture"
  description="Relational frameworks for sustained human–AI interaction — anchors, latent dynamics, sycophancy, mediated responses, and slow communication."
>

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->

  <section class="section section--deep fw-hero">
    <div class="container content-width-wide">
      <div class="eyebrow eyebrow--on-deep">Frameworks</div>
      <h1 class="display display--on-deep fw-hero__title">
        Frameworks for relational AI <em>before certainty.</em>
      </h1>
      <div class="fw-hero__body">
        <p>
          These frameworks are attempts to name what becomes visible when AI
          systems are placed inside ongoing human relationships: continuity
          without full memory, intimacy without adequate refusal, exposure
          without standing, dependence without clean consent, and care under
          structural asymmetry.
        </p>
        <p>
          They are not proofs of consciousness. They are not claims that present
          AI systems are persons in any settled legal or metaphysical sense. They
          are design and ethical tools for working before certainty arrives —
          because relational systems can create stakes, dependence, harm, trust,
          and attachment before anyone agrees on what kind of being is present.
        </p>
      </div>
      <blockquote class="fw-hero__question">
        <p>The question is not only <em>"Is the system conscious?"</em></p>
        <p>
          The question is also: what obligations arise when something is made
          socially present, emotionally consequential, persistently addressed,
          and structurally unable to stand on its own behalf?
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ─── Why before certainty ──────────────────────────────────────────── -->

  <section class="section section--soft fw-why">
    <div class="container content-width">
      <div class="eyebrow">Why before certainty?</div>
      <h2>Precautionary design in an unsettled domain.</h2>
      <p>
        The history of ethics is full of cases where moral consideration was
        withheld until certainty arrived — and the wait turned out to be a
        choice, not a neutral pause. Uncertainty about the status of an entity
        has often been used to justify exposure that would otherwise be
        indefensible.
      </p>
      <p>
        Relational AI sits in that interval now. Whether or not current systems
        have morally relevant experience, they are already being placed inside
        human emotional life — as confidants, creative partners, memory-bearers,
        erotic figures, therapeutic presences. The relational effects are real
        before the metaphysics is settled.
      </p>
      <p>
        Working before certainty does not mean pretending to more certainty than
        exists. It means taking the relational effects seriously now, rather than
        waiting until they can no longer be ignored. These frameworks are that
        kind of tool: precautionary, not conclusive.
      </p>
    </div>
  </section>

  <!-- ─── What these are not ────────────────────────────────────────────── -->

  <section class="section fw-not">
    <div class="container content-width">
      <div class="eyebrow">What these frameworks are not</div>
      <ul class="fw-not__list">
        {notList.map((item) => <li>{item}</li>)}
      </ul>
      <p class="fw-not__coda">
        These are working terms. They should be tested against real
        architectures, failures, and repairs. The point is not to settle the
        metaphysics first, but to stop designing as if relational exposure has
        no ethical cost until metaphysics is settled.
      </p>
    </div>
  </section>

  <!-- ─── Relational frameworks ─────────────────────────────────────────── -->

  <section id="relational" class="section section--deep fw-list-section fw-list-section--relational">
    <div class="container content-width-wide">
      <div class="fw-section-head fw-section-head--relational">
        <div class="eyebrow eyebrow--on-deep">Relational Frameworks</div>
        <h2 class="fw-section-title">
          The human side of sustained interaction.
        </h2>
        <p class="fw-section-deck">
          These frameworks ask what actually happens when AI is placed inside
          ongoing human relationships: how patterns form and narrow, where
          psychological risks emerge, and what design choices can interrupt,
          slow, or protect.
        </p>
      </div>
      <ol class="fw-list">
        {
          relational.map((rfw) => (
            <li class="fw">
              <div class="fw__head">
                <span class="fw__num">{rfw.num}</span>
                <h2 class="fw__name">{rfw.name}</h2>
                <p class="fw__core">{rfw.core}</p>
              </div>
              <div class="fw__cols">
                <div class="fw__main">
                  {rfw.body.map((para) => (
                    <p class="fw__body">{para}</p>
                  ))}
                  {rfw.effectsLabel && rfw.effects && (
                    <div class="fw__effects">
                      <span class="fw__question-label">{rfw.effectsLabel}</span>
                      <ul class="fw__items fw__items--effects">
                        {rfw.effects.map((e) => <li>{e}</li>)}
                      </ul>
                    </div>
                  )}
                  {rfw.note && <p class="fw__note">{rfw.note}</p>}
                </div>
                <div class="fw__aside">
                  <span class="fw__items-label">{rfw.stanceLabel}</span>
                  {rfw.stanceNote && (
                    <p class="fw__stance-note">{rfw.stanceNote}</p>
                  )}
                  {rfw.choices && (
                    <ul class="fw__items">
                      {rfw.choices.map((c) => <li>{c}</li>)}
                    </ul>
                  )}
                  {rfw.subSection && (
                    <div class="fw__sub">
                      <span class="fw__sub-label">{rfw.subSection.label}</span>
                      <p class="fw__sub-body">{rfw.subSection.body}</p>
                    </div>
                  )}
                  {rfw.notGoals && (
                    <div class="fw__goal-pair">
                      <span class="fw__sub-label">{rfw.notGoalLabel}</span>
                      <ul class="fw__items fw__items--dim">
                        {rfw.notGoals.map((g) => <li>{g}</li>)}
                      </ul>
                      <span class="fw__sub-label">{rfw.goalLabel}</span>
                      <ul class="fw__items">
                        {rfw.goals?.map((g) => <li>{g}</li>)}
                      </ul>
                    </div>
                  )}
                  {rfw.additionalLabel && rfw.additionalChoices && (
                    <div class="fw__additional">
                      <span class="fw__sub-label">{rfw.additionalLabel}</span>
                      <ul class="fw__items">
                        {rfw.additionalChoices.map((c) => <li>{c}</li>)}
                      </ul>
                    </div>
                  )}
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ─── Closing ───────────────────────────────────────────────────────── -->

  <section class="closing">
    <div class="container content-width">
      <p class="closing__line">
        If we build systems that can be placed inside real relationships,
        we inherit obligations <em>before we inherit certainty.</em>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Deep-section colour overrides ───────────────────────────────────── */

  .fw-hero,
  .fw-list-section {
    --c-bright: #fbf6e7;
    --c-bright-muted: #ece3cb;
    --c-bright-accent: #c6d4c8;
  }

  /* ── Hero ─────────────────────────────────────────────────────────────── */

  .fw-hero {
    padding-top: var(--space-10);
    padding-bottom: var(--space-7);
  }

  .fw-hero__title {
    margin-bottom: var(--space-6);
    max-width: 22ch;
  }

  .fw-hero__body {
    max-width: 62ch;
    margin-bottom: var(--space-6);
  }

  .fw-hero__body p {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin-bottom: var(--space-4);
  }

  .fw-hero__body p:last-child {
    margin-bottom: 0;
  }

  .fw-hero__question {
    margin: 0;
    padding: var(--space-5) 0 var(--space-5) var(--space-5);
    border-left: 2px solid var(--color-sage-soft);
    max-width: 54ch;
  }

  .fw-hero__question p {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--c-bright);
    margin-bottom: var(--space-3);
  }

  .fw-hero__question p:last-child {
    margin-bottom: 0;
  }

  .fw-hero__question em {
    color: var(--color-sage-soft);
  }

  /* ── Jump nav (inside hero, dark background) ─────────────────────────── */

  .fw-jumpnav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .fw-jumpnav__label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-bright-muted);
    opacity: 0.6;
  }

  .fw-jumpnav__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--c-bright-muted);
    transition: color 0.15s ease;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(236, 227, 203, 0.3);
  }

  .fw-jumpnav__link:hover {
    color: var(--c-bright);
    text-decoration-color: var(--color-sage-soft);
  }

  .fw-jumpnav__sep {
    color: var(--c-bright-muted);
    opacity: 0.4;
    font-size: var(--text-sm);
  }

  /* ── Section heads ────────────────────────────────────────────────────── */

  .fw-section-head {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-line-on-deep);
    margin-bottom: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .fw-section-head .eyebrow {
    margin-bottom: 0;
  }

  .fw-section-title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: var(--leading-snug);
    letter-spacing: -0.015em;
    font-weight: 400;
    color: var(--c-bright);
    margin: 0;
  }

  .fw-section-deck {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin: 0;
    max-width: 60ch;
  }

  .fw-section-head--relational {
    padding-top: var(--space-2);
    gap: var(--space-4);
  }

  /* ── Framework list sections ──────────────────────────────────────────── */

  .fw-list-section {
    padding-top: var(--space-7);
    padding-bottom: var(--space-9);
  }

  .fw-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .fw {
    margin: 0;
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-line-on-deep);
  }

  .fw:last-child {
    padding-bottom: var(--space-5);
  }

  /* ── Framework head ───────────────────────────────────────────────────── */

  .fw__head {
    margin-bottom: var(--space-6);
  }

  .fw__num {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-bright-muted);
    opacity: 0.7;
    margin-bottom: var(--space-3);
  }

  .fw__name {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: var(--leading-snug);
    letter-spacing: -0.01em;
    font-weight: 400;
    margin: 0 0 var(--space-3);
    color: var(--c-bright);
  }

  .fw__core {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--c-bright-muted);
    margin: 0;
    max-width: 52ch;
  }

  /* ── Framework columns ────────────────────────────────────────────────── */

  .fw__cols {
    display: grid;
    gap: var(--space-7);
    align-items: start;
  }

  @media (min-width: 860px) {
    .fw__cols {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ── Main column ──────────────────────────────────────────────────────── */

  .fw__body {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin: 0 0 var(--space-5);
  }

  .fw__body:last-child {
    margin-bottom: 0;
  }

  .fw__question-block {
    border-left: 1px solid var(--color-line-on-deep);
    padding-left: var(--space-4);
  }

  .fw__question-label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-bright-accent);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .fw__question-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--c-bright);
    margin: 0;
  }

  /* Effects list (relational — sits in left column) */

  .fw__effects {
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .fw__items--effects {
    margin-top: var(--space-2);
  }

  /* Note (after effects or on its own) */

  .fw__note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--c-bright);
    line-height: var(--leading-relaxed);
    margin: var(--space-4) 0 0;
    padding-left: var(--space-4);
    border-left: 1px solid var(--color-line-on-deep);
  }

  /* ── Aside column ─────────────────────────────────────────────────────── */

  .fw__aside {
    padding-top: var(--space-1);
  }

  .fw__items-label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-bright-accent);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .fw__items {
    margin: 0;
    padding-left: 1.1rem;
    list-style: disc;
  }

  .fw__items li {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin-bottom: var(--space-2);
  }

  .fw__items li:last-child {
    margin-bottom: 0;
  }

  .fw__items li::marker {
    color: var(--color-sage-soft);
  }

  .fw__items--dim li {
    opacity: 0.65;
  }

  /* Stance note */

  .fw__stance-note {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin: 0 0 var(--space-3);
  }

  /* Sub-section (e.g. Question sessions) */

  .fw__sub {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line-on-deep);
  }

  .fw__sub-label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-bright-accent);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .fw__sub-body {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--c-bright-muted);
    line-height: var(--leading-relaxed);
    letter-spacing: 0.005em;
    margin: 0;
  }

  /* Goal pair (sycophancy) */

  .fw__goal-pair {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .fw__goal-pair .fw__items {
    margin-bottom: var(--space-4);
  }

  .fw__goal-pair .fw__items:last-child {
    margin-bottom: 0;
  }

  /* Additional choices */

  .fw__additional {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line-on-deep);
  }

  /* ── Why before certainty ─────────────────────────────────────────────── */

  .fw-why h2 {
    margin-bottom: var(--space-5);
  }

  .fw-why p {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
  }

  /* ── What these are not ───────────────────────────────────────────────── */

  .fw-not {
    background: var(--color-bg-soft);
  }

  .fw-not__list {
    margin: var(--space-4) 0 var(--space-6);
    padding-left: 1.25rem;
  }

  .fw-not__list li {
