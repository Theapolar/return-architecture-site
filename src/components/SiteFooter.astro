---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__top">
      <a href="/" class="site-footer__brand">Return Architecture</a>
      <p class="site-footer__tagline">
        Architecture for sustained AI relations. <em>Built for return, not retention.</em>
      </p>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__credit">
        By Thea Borch. Built with Claude.
      </p>
      <p class="site-footer__legal">
        © {year} Thea Borch · <a href="mailto:thea@theaborch.com">thea@theaborch.com</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-7) 0 var(--space-6);
    border-top: 1px solid var(--color-line);
    margin-top: var(--space-8);
  }

  .site-footer__inner {
    display: grid;
    gap: var(--space-5);
  }

  .site-footer__top {
    display: grid;
    gap: var(--space-2);
  }

  .site-footer__brand {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-footer__tagline {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    max-width: 50ch;
    line-height: var(--leading-snug);
    letter-spacing: -0.005em;
  }

  .site-footer__tagline em {
    font-style: italic;
    color: var(--color-sage-deep);
  }

  .site-footer__bottom {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-line-soft);
  }

  .site-footer__credit {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: var(--leading-relaxed);
  }

  .site-footer__legal {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    letter-spacing: 0.02em;
  }

  .site-footer__legal a {
    color: inherit;
    border-bottom: 1px solid var(--color-line);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .site-footer__legal a:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
</style>
